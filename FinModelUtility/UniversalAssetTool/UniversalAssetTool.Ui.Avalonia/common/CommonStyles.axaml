<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
        xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <Design.PreviewWith>
    <StackPanel Width="300" Height="900">
      <Panel Width="96"
             Height="96"
             Background="{StaticResource CheckeredBackgroundBrush}" />
    </StackPanel>
  </Design.PreviewWith>

  <Styles.Resources>
    <ResourceDictionary>
      <ImageBrush x:Key="CheckeredBackgroundBrush" 
                  Source="/Assets/checkered_background.png"
                  TileMode="Tile"
                  Stretch="Uniform"
                  DestinationRect="0,0,32,32" />
    </ResourceDictionary>
  </Styles.Resources>
</Styles>