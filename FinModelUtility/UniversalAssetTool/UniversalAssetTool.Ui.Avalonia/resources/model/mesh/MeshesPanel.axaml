<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mesh="clr-namespace:uni.ui.avalonia.resources.model.mesh"
             xmlns:controls="clr-namespace:fin.ui.avalonia.controls;assembly=Fin.Ui.Avalonia"
             xmlns:controls1="clr-namespace:uni.ui.avalonia.common.controls"
             xmlns:resources="clr-namespace:uni.ui.avalonia.resources"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="uni.ui.avalonia.resources.model.mesh.MeshesPanel"
             x:DataType="mesh:MeshesPanelViewModel">
  <Design.DataContext>
    <mesh:MeshesPanelViewModelForDesigner />
  </Design.DataContext>

  <controls:If Condition="{Binding IsPopulated}">
    <controls:If.ContentWhenTrue>
      <Border BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1">
        <resources:FullHierarchyTree DataContext="{Binding Impl}" />
      </Border>
    </controls:If.ContentWhenTrue>
    <controls:If.ContentWhenFalse>
      <controls1:EmptyState
          Text="No meshes to display."
          Icon="{StaticResource MeshIcon}" />
    </controls:If.ContentWhenFalse>
  </controls:If>
</UserControl>