<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:areas="clr-namespace:uni.ui.avalonia.resources.scene.areas"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
             x:Class="uni.ui.avalonia.resources.scene.areas.FullHierarchyTree"
             x:DataType="areas:FullHierarchyTreeViewModel">
  <Design.DataContext>
    <areas:FullHierarchyTreeViewModelForDesigner />
  </Design.DataContext>

  <TreeDataGrid
      Source="{Binding Source}"
      ShowColumnHeaders="False"
      CanUserResizeColumns="False">
    <TreeDataGrid.Styles>
      <Style Selector="TreeDataGridCellsPresenter">
        <Setter Property="Height" Value="{StaticResource RegularHeight}" />
      </Style>
    </TreeDataGrid.Styles>
  </TreeDataGrid>
</UserControl>