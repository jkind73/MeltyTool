<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250"
             Height="28"
             x:Class="MarioArtistTool.file_select.FileSelectTopBar">
  <Grid Background="Black">
    <StackPanel>
      <Button x:Name="DiskSwapButton"
              ToolTip.Tip="Swap 64DD disk file"
              Margin="28 -2 0 0"
              Width="39"
              Height="33">
        <Image x:Name="DiskSwapIcon"
               Height="21"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
      </Button>
	</StackPanel>

	<Image Source="/Assets/file_select/top_bar/top_bar.png"
           Height="28"
           IsHitTestVisible="False"
           HorizontalAlignment="Left" />
  </Grid>
</UserControl>