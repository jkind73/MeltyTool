<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:marioartisttool.ViewModels"
             xmlns:scene="clr-namespace:fin.ui.avalonia.scene;assembly=Fin.Ui.Avalonia"
             xmlns:controls="clr-namespace:fin.ui.avalonia.controls;assembly=Fin.Ui.Avalonia"
             xmlns:fileSelect="clr-namespace:marioartisttool.file_select"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="marioartisttool.Views.MainView"
             x:DataType="vm:MainViewModel"
             Cursor="{Binding ThumbInCursor}">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModelForDesigner />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TreeDataGridExpanderCell DockPanel > Border">
      <Setter Property="IsVisible" Value="False" />
    </Style>

    <Style Selector="Border.TreeDirectory">
      <Setter Property="BorderBrush" Value="#F5B500" />
      <Setter Property="BorderThickness" Value="3" />
    </Style>

    <Style Selector="Border.TreeFile">
      <Setter Property="BorderBrush" Value="White" />
      <Setter Property="BorderThickness" Value="3" />
    </Style>

    <Style Selector="Border.TreeDirectory:pointerover,
		                 Border.TreeFile:pointerover">
      <Setter Property="BorderBrush" Value="#EC1417" />
    </Style>

    <Style Selector=":selected Border.TreeFile">
      <Setter Property="BorderBrush" Value="#F5B500" />
    </Style>

	  <Style Selector=":focus Border.TreeDirectory,
		                 :focus Border.TreeFile">
      <Setter Property="BorderBrush" Value="#44433D" />
    </Style>

    <Style Selector="TreeDataGridExpanderCell">
      <Setter Property="Width" Value="242" />
    </Style>

    <Style Selector="TreeDataGridExpanderCell,
                     TreeDataGridRow,
                     TreeDataGridTemplateCell">
      <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style Selector=":selected .TreeFile Image">
      <Setter Property="Opacity" Value=".8" />
    </Style>
    <Style Selector=":selected .TreeFile TextBlock">
      <Setter Property="Opacity" Value=".8" />
    </Style>
  </UserControl.Styles>

  <DockPanel>
    <DockPanel Width="250"
               DockPanel.Dock="Left">
      <fileSelect:FileSelectTopBar DockPanel.Dock="Top" />

      <Panel>
        <Border>
          <Border.Background>
            <ImageBrush Source="/Assets/file_select/background.png"
                        TileMode="Tile"
                        Stretch="Uniform"
                        DestinationRect="0,0,32,32" />
          </Border.Background>
        </Border>

        <Image Source="/Assets/file_select/gradient_dark.png"
               Stretch="Fill"
               BlendMode="Multiply"
               Opacity=".5" />

        <Image Source="/Assets/file_select/gradient_light.png"
               Stretch="Fill"
               BlendMode="ColorDodge"
               Opacity=".9" />

        <Border Padding="4">
          <controls:If Condition="{Binding FileSystemTreeSource, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TreeDataGrid x:Name="FileTree"
                          Source="{Binding FileSystemTreeSource}" />
          </controls:If>
        </Border>
      </Panel>
    </DockPanel>

    <Panel>
      <scene:SceneInstanceViewerGlPanel
          x:Name="ViewerGlPanel"
          IsTabStop="True"
          TabIndex="0"
          Focusable="True"
          ShowGrid="True"
          UseRenderGraph="False"
          HorizontalAlignment="Stretch" 
          VerticalAlignment="Stretch" />
      <TextBlock Text="{Binding FileLabel}"
                 Foreground="White"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0 16"
                 FontSize="24"
                 FontWeight="Bold">
		    <TextBlock.Effect>
          <DropShadowEffect OffsetX="1"
                            OffsetY="2"
                            BlurRadius="0"
                            Color="{DynamicResource Black}" />
        </TextBlock.Effect>
	    </TextBlock>
    </Panel>
  </DockPanel>
</UserControl>