+TEST_F(utFBXImporterExporter, exportMorphAnimationRoundTrip) {
+    aiScene scene;
+    scene.mRootNode = new aiNode("Root");
+    scene.mRootNode->mNumChildren = 1;
+    scene.mRootNode->mChildren = new aiNode *[1];
+    aiNode *meshNode = new aiNode("mesh0");
+    meshNode->mParent = scene.mRootNode;
+    meshNode->mNumMeshes = 1;
+    meshNode->mMeshes = new unsigned int[1]{0};
+    scene.mRootNode->mChildren[0] = meshNode;
+
+    scene.mNumMaterials = 1;
+    scene.mMaterials = new aiMaterial *[1]{new aiMaterial()};
+    scene.mNumMeshes = 1;
+    scene.mMeshes = new aiMesh *[1];
+    aiMesh *mesh = new aiMesh();
+    mesh->mName.Set("mesh0");
+    mesh->mMaterialIndex = 0;
+    mesh->mNumVertices = 3;
+    mesh->mVertices = new aiVector3D[3]{{0, 0, 0}, {1, 0, 0}, {0, 1, 0}};
+    mesh->mNumFaces = 1;
+    mesh->mFaces = new aiFace[1];
+    mesh->mFaces[0].mNumIndices = 3;
+    mesh->mFaces[0].mIndices = new unsigned int[3]{0, 1, 2};
+    mesh->mNumAnimMeshes = 1;
+    mesh->mAnimMeshes = new aiAnimMesh *[1];
+    aiAnimMesh *target = new aiAnimMesh();
+    target->mName.Set("target0");
+    target->mNumVertices = 3;
+    target->mVertices = new aiVector3D[3]{{0, 0, 0}, {1, 0, 0}, {0, 2, 0}};
+    mesh->mAnimMeshes[0] = target;
+    scene.mMeshes[0] = mesh;
+
+    scene.mNumAnimations = 1;
+    scene.mAnimations = new aiAnimation *[1];
+    aiAnimation *animation = new aiAnimation();
+    animation->mName.Set("morph");
+    animation->mDuration = 1.0;
+    animation->mTicksPerSecond = 10.0;
+    animation->mNumMorphMeshChannels = 1;
+    animation->mMorphMeshChannels = new aiMeshMorphAnim *[1];
+    aiMeshMorphAnim *channel = new aiMeshMorphAnim();
+    channel->mName.Set("mesh0");
+    channel->mNumKeys = 2;
+    channel->mKeys = new aiMeshMorphKey[2];
+    for (unsigned int i = 0; i < 2; ++i) {
+        channel->mKeys[i].mTime = static_cast<double>(i);
+        channel->mKeys[i].mNumValuesAndWeights = 1;
+        channel->mKeys[i].mValues = new unsigned int[1]{0};
+        channel->mKeys[i].mWeights = new double[1]{static_cast<double>(i)};
+    }
+    animation->mMorphMeshChannels[0] = channel;
+    scene.mAnimations[0] = animation;
+
+    Assimp::Exporter exporter;
+    ASSERT_EQ(AI_SUCCESS, exporter.Export(&scene, "fbx", "morph-animation-roundtrip.fbx")) << exporter.GetErrorString();
+    Assimp::Importer importer;
+    const aiScene *roundTrip = importer.ReadFile("morph-animation-roundtrip.fbx", 0);
+    ASSERT_NE(nullptr, roundTrip) << importer.GetErrorString();
+    ASSERT_EQ(1u, roundTrip->mNumMeshes);
+    ASSERT_EQ(1u, roundTrip->mMeshes[0]->mNumAnimMeshes);
+    ASSERT_EQ(1u, roundTrip->mNumAnimations);
+    ASSERT_EQ(1u, roundTrip->mAnimations[0]->mNumMorphMeshChannels);
+    const aiMeshMorphAnim *roundTripChannel = roundTrip->mAnimations[0]->mMorphMeshChannels[0];
+    ASSERT_EQ(2u, roundTripChannel->mNumKeys);
+    EXPECT_DOUBLE_EQ(0.0, roundTripChannel->mKeys[0].mWeights[0]);
+    EXPECT_DOUBLE_EQ(1.0, roundTripChannel->mKeys[1].mWeights[0]);
+}
